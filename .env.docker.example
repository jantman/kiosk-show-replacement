# Docker Environment Configuration for kiosk-show-replacement
# Copy this file to .env and configure for your deployment
#
# For production: docker-compose -f docker-compose.prod.yml up -d
# For development: docker-compose up

# =============================================================================
# REQUIRED - These must be set for production
# =============================================================================

# Flask secret key for session security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# MariaDB root password (production only)
MYSQL_ROOT_PASSWORD=change-this-root-password

# MariaDB application user password (production only)
MYSQL_PASSWORD=change-this-password

# Admin user password for initial setup (default matches README quick start)
# IMPORTANT: Change this to a secure password for production!
KIOSK_ADMIN_PASSWORD=admin

# =============================================================================
# OPTIONAL - These have sensible defaults
# =============================================================================

# Timezone for calendar display (Skedda slide times, date boundaries).
# Must be a valid IANA timezone name. See:
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Default: America/New_York
# TZ=America/New_York

# Application port (default: 5000)
# APP_PORT=5000

# MariaDB database name (default: kiosk_show)
# MYSQL_DATABASE=kiosk_show

# MariaDB application user (default: kiosk)
# MYSQL_USER=kiosk

# MariaDB host (optional; if set along with MYSQL_USER, MYSQL_PASSWORD, and
# MYSQL_DATABASE, the application will auto-construct DATABASE_URL when it is
# not explicitly set). This is useful when running the container outside of
# docker-compose.prod.yml.
# MYSQL_HOST=mariadb

# MariaDB port (default: 3306)
# MYSQL_PORT=3306

# Admin username for initial setup (default: admin)
# KIOSK_ADMIN_USERNAME=admin

# Admin email (optional)
# KIOSK_ADMIN_EMAIL=admin@example.com

# Number of Gunicorn workers (default: 2)
# For Raspberry Pi, consider setting to 1
# GUNICORN_WORKERS=2

# =============================================================================
# NEWRELIC APM MONITORING (Optional)
# =============================================================================
# NewRelic is automatically enabled when NEW_RELIC_LICENSE_KEY is set.
# Get your license key from: https://one.newrelic.com/admin-portal/api-keys/home

# NewRelic license key (required to enable monitoring)
# NEW_RELIC_LICENSE_KEY=your-newrelic-license-key

# Application name shown in NewRelic dashboard (default: kiosk-show-replacement)
# NEW_RELIC_APP_NAME=kiosk-show-replacement

# Environment tag for NewRelic (e.g., production, staging)
# NEW_RELIC_ENVIRONMENT=production

# NewRelic log level (default: info)
# Options: critical, error, warning, info, debug
# NEW_RELIC_LOG_LEVEL=info

# Enable browser monitoring auto-instrumentation (default: true)
# Injects the NewRelic Browser JavaScript agent into HTML pages.
# NEW_RELIC_BROWSER_MONITORING_AUTO_INSTRUMENT=true

# Enable distributed tracing (default: true)
# NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true

# Enable transaction tracing for slow requests (default: true)
# NEW_RELIC_TRANSACTION_TRACER_ENABLED=true

# Enable slow SQL query monitoring (default: true)
# NEW_RELIC_SLOW_SQL_ENABLED=true

# Enable error collection (default: true)
# NEW_RELIC_ERROR_COLLECTOR_ENABLED=true

# Enable thread profiling (default: true)
# NEW_RELIC_THREAD_PROFILER_ENABLED=true

# =============================================================================
# DEVELOPMENT ONLY - Not used in production compose
# =============================================================================

# Flask environment (default in dev compose: development)
# FLASK_ENV=development

# Flask debug mode (default in dev compose: 1)
# FLASK_DEBUG=1
